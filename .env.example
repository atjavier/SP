# Copy this file to ".env" and adjust paths for your machine.
# NOTE: real environment variables still override values in .env.

# --- Server ---
# SP_HOST=127.0.0.1
# SP_PORT=8000
# SP_WAITRESS_THREADS=16

# --- Database ---
# SP_DB_PATH=instance/sp.db

# --- SnpEff (annotation stage) ---
# If you set SP_SNPEFF_ENABLED=0, the annotation stage will skip SnpEff.
SP_SNPEFF_ENABLED=1

# Option A: point to the folder that contains snpEff.jar
# SP_SNPEFF_HOME=C:\tools\snpEff

# Option B: point directly to snpEff.jar
# SP_SNPEFF_JAR_PATH=C:\tools\snpEff\snpEff.jar

# Data dir (recommended on Windows): keep it under SP_SNPEFF_HOME and use a relative path.
SP_SNPEFF_DATA_DIR=./data

# Genome build (SnpEff database key)
SP_SNPEFF_GENOME=GRCh38.86

# Optional overrides
# SP_JAVA_CMD=java
# SP_SNPEFF_JAVA_XMX=2g
# SP_SNPEFF_TIMEOUT_SECONDS=900

# --- VEP (prediction stage: SIFT + PolyPhen + AlphaMissense plugin) ---
# Command used to invoke VEP.
# Use "vep" if on PATH, or a full executable path.
# SP_VEP_CMD=vep

# Optional script path appended after SP_VEP_CMD.
# Useful if SP_VEP_CMD points to perl/python and script is separate.
# SP_VEP_SCRIPT_PATH=

# Required: VEP cache directory for offline mode.
# SP_VEP_CACHE_DIR=C:\tools\vep\cache

# Optional: VEP plugin directory (if needed by your installation).
# SP_VEP_PLUGIN_DIR=C:\tools\vep\plugins

# Required: AlphaMissense plugin data file path.
# SP_VEP_ALPHAMISSENSE_FILE=C:\tools\vep\plugins\AlphaMissense_hg38.tsv.gz

# Optional: reference FASTA path.
# SP_VEP_FASTA_PATH=C:\tools\reference\GRCh38.fa

# Optional: assembly (default GRCh38), timeout in seconds, and extra args.
# SP_VEP_ASSEMBLY=GRCh38
# SP_VEP_TIMEOUT_SECONDS=1200
# SP_VEP_EXTRA_ARGS=

# --- Docker (real VEP profile) ---
# For Docker Compose runtime that installs VEP under /opt/vep:
# SP_VEP_CMD=perl
# SP_VEP_SCRIPT_PATH=/opt/vep/ensembl-vep/vep
# SP_VEP_CACHE_DIR=/opt/vep/.vep
# SP_VEP_PLUGIN_DIR=/opt/vep/.vep/Plugins
# SP_VEP_ALPHAMISSENSE_FILE=/opt/vep/.vep/Plugins/AlphaMissense_hg38.tsv.gz
# SP_SNPEFF_HOME=/opt/snpeff/snpEff
# SP_SNPEFF_JAR_PATH=/opt/snpeff/snpEff/snpEff.jar
