# Copy this file to ".env" and adjust paths for your machine.
# NOTE: real environment variables still override values in .env.

# --- Server ---
# SP_HOST=127.0.0.1
# SP_PORT=8000
# SP_WAITRESS_THREADS=16

# --- Database ---
# SP_DB_PATH=instance/sp.db

# --- Evidence Retrieval Profile ---
# full: query evidence sources for all variants (default behavior).
# minimum_exome: only query evidence for variants classified as coding
#                (synonymous/missense/nonsense) to reduce runtime/API load.
# predictor_only: only query evidence for predictor-routed variants
#                 (currently missense), for fastest runs.
# SP_EVIDENCE_PROFILE=full

# Evidence source mode:
# - online: query remote APIs only
# - offline: query local VCF/tabix databases only
# - hybrid: prefer local VCF/tabix and fall back to remote APIs on local errors
# SP_EVIDENCE_MODE=hybrid

# --- SnpEff (annotation stage) ---
# If you set SP_SNPEFF_ENABLED=0, the annotation stage will skip SnpEff.
SP_SNPEFF_ENABLED=1

# Option A: point to the folder that contains snpEff.jar
# SP_SNPEFF_HOME=C:\tools\snpEff

# Option B: point directly to snpEff.jar
# SP_SNPEFF_JAR_PATH=C:\tools\snpEff\snpEff.jar

# Data dir (recommended on Windows): keep it under SP_SNPEFF_HOME and use a relative path.
SP_SNPEFF_DATA_DIR=./data

# Genome build (SnpEff database key)
SP_SNPEFF_GENOME=GRCh38.86

# Optional overrides
# SP_JAVA_CMD=java
# SP_SNPEFF_JAVA_XMX=2g
# SP_SNPEFF_TIMEOUT_SECONDS=900

# --- VEP (prediction stage: SIFT + PolyPhen + AlphaMissense plugin) ---
# Command used to invoke VEP.
# Use "vep" if on PATH, or a full executable path.
# SP_VEP_CMD=vep

# Optional script path appended after SP_VEP_CMD.
# Useful if SP_VEP_CMD points to perl/python and script is separate.
# SP_VEP_SCRIPT_PATH=

# Required: VEP cache directory for offline mode.
# SP_VEP_CACHE_DIR=C:\tools\vep\cache

# Optional: VEP plugin directory (if needed by your installation).
# SP_VEP_PLUGIN_DIR=C:\tools\vep\plugins

# Required: AlphaMissense plugin data file path.
# SP_VEP_ALPHAMISSENSE_FILE=C:\tools\vep\plugins\AlphaMissense_hg38.tsv.gz

# Optional: reference FASTA path.
# SP_VEP_FASTA_PATH=C:\tools\reference\GRCh38.fa

# Optional: assembly (default GRCh38), timeout in seconds, and extra args.
# SP_VEP_ASSEMBLY=GRCh38
# SP_VEP_TIMEOUT_SECONDS=1200
# SP_VEP_EXTRA_ARGS=

# --- Docker (real VEP profile) ---
# For Docker Compose runtime that installs VEP under /opt/vep:
# SP_VEP_CMD=perl
# SP_VEP_SCRIPT_PATH=/opt/vep/ensembl-vep/vep
# SP_VEP_CACHE_DIR=/opt/vep/.vep
# SP_VEP_PLUGIN_DIR=/opt/vep/.vep/Plugins
# SP_VEP_ALPHAMISSENSE_FILE=/opt/vep/.vep/Plugins/AlphaMissense_hg38.tsv.gz
# SP_SNPEFF_HOME=/opt/snpeff/snpEff
# SP_SNPEFF_JAR_PATH=/opt/snpeff/snpEff/snpEff.jar

# --- dbSNP (annotation evidence stage) ---
# Set SP_DBSNP_ENABLED=0 to skip dbSNP retrieval.
SP_DBSNP_ENABLED=1

# Optional overrides
# SP_DBSNP_API_BASE_URL=https://api.ncbi.nlm.nih.gov/variation/v0
# SP_DBSNP_TIMEOUT_SECONDS=10
# SP_DBSNP_RETRY_MAX_ATTEMPTS=3
# SP_DBSNP_RETRY_BACKOFF_BASE_SECONDS=0.5
# SP_DBSNP_RETRY_BACKOFF_MAX_SECONDS=8
# SP_DBSNP_API_KEY=
# SP_DBSNP_ASSEMBLY=GRCh38
# SP_DBSNP_LOCAL_VCF_PATH=/opt/evidence/dbsnp/dbsnp_all_grch38.vcf.gz

# --- ClinVar (annotation evidence stage) ---
# Set SP_CLINVAR_ENABLED=0 to skip ClinVar retrieval.
SP_CLINVAR_ENABLED=1

# Optional overrides
# SP_CLINVAR_API_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
# SP_CLINVAR_TIMEOUT_SECONDS=10
# SP_CLINVAR_RETRY_MAX_ATTEMPTS=3
# SP_CLINVAR_RETRY_BACKOFF_BASE_SECONDS=0.5
# SP_CLINVAR_RETRY_BACKOFF_MAX_SECONDS=8
# SP_CLINVAR_API_KEY=
# SP_CLINVAR_LOCAL_VCF_PATH=/opt/evidence/clinvar/clinvar_grch38.vcf.gz

# --- gnomAD (annotation evidence stage) ---
# Set SP_GNOMAD_ENABLED=0 to skip gnomAD lookups.
SP_GNOMAD_ENABLED=1

# Optional overrides
# SP_GNOMAD_API_BASE_URL=https://gnomad.broadinstitute.org/api
# SP_GNOMAD_DATASET_ID=gnomad_r4
# SP_GNOMAD_REFERENCE_GENOME=GRCh38
# SP_GNOMAD_TIMEOUT_SECONDS=10
# SP_GNOMAD_RETRY_MAX_ATTEMPTS=3
# SP_GNOMAD_RETRY_BACKOFF_BASE_SECONDS=0.5
# SP_GNOMAD_RETRY_BACKOFF_MAX_SECONDS=8
# SP_GNOMAD_MIN_REQUEST_INTERVAL_SECONDS=1.0
# Project decision: keep gnomAD online by default due local dataset size.
# Future researchers may add local gnomAD if resources permit.

# --- Optional: local evidence bootstrap URLs (Docker sp-evidence-init) ---
# INSTALL_DBSNP=1
# INSTALL_CLINVAR=1
# DBSNP_VCF_URL=https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.40.gz
# DBSNP_TBI_URL=https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.40.gz.tbi
# CLINVAR_VCF_URL=https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/clinvar.vcf.gz
# CLINVAR_TBI_URL=https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/clinvar.vcf.gz.tbi

# Default run policy for annotation evidence-source failures.
# - continue: annotation succeeds with warnings/partial evidence
# - stop: annotation fails on first source retrieval failure
# Most users should leave this as "continue" and choose per-run behavior in the UI.
# SP_ANNOTATION_EVIDENCE_POLICY_DEFAULT=continue

# Legacy fallback only (kept for backward compatibility):
# If SP_ANNOTATION_EVIDENCE_POLICY_DEFAULT is not set, this flag is used.
# 0 => continue, 1 => stop
# SP_ANNOTATION_FAIL_ON_EVIDENCE_ERROR=0
